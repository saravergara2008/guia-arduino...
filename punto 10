// Definimos los pines de los 3 LEDs según las conexiones de la imagen
const int ledVerde = 13;   // Conectado al pin 13 (cable verde)
const int ledAmarillo = 12; // Conectado al pin 12 (cable amarillo)
const int ledAzul = 8;      // Conectado al pin 8 (cable azul)

void setup() {
  // Configurar los 3 pines como salidas (OUTPUT)
  pinMode(ledVerde, OUTPUT);
  pinMode(ledAmarillo, OUTPUT);
  pinMode(ledAzul, OUTPUT);
}

void loop() {
  // 1. Enciende el primer LED (Pin 13)
  digitalWrite(ledVerde, HIGH);
  delay(500); // Espera medio segundo
  digitalWrite(ledVerde, LOW);
  
  // 2. Enciende el segundo LED (Pin 12)
  digitalWrite(ledAmarillo, HIGH);
  delay(500);
  digitalWrite(ledAmarillo, LOW);
  
  // 3. Enciende el tercer LED (Pin 8)
  digitalWrite(ledAzul, HIGH);
  delay(500);
  digitalWrite(ledAzul, LOW);
}
