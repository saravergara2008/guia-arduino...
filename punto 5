// Definimos el pin digital donde está conectado el cable rojo
const int ledPin = 13; // Cambia a 9 si tu cable rojo está en el pin 9

void setup() {
  // Configura el pin digital como salida
  pinMode(ledPin, OUTPUT);
}

void loop() {
  digitalWrite(ledPin, HIGH); // Enciende el LED amarillo
  delay(1000);                // Espera 1 segundo (1000 milisegundos)
  digitalWrite(ledPin, LOW);  // Apaga el LED amarillo
  delay(1000);                // Espera 1 segundo
}
