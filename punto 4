// Definimos los pines a los que están conectados los 4 LEDs
const int led1 = 2;
const int led2 = 3;
const int led3 = 4;
const int led4 = 5;

void setup() {
  // Configurar los 4 pines digitales como salidas (OUTPUT)
  pinMode(led1, OUTPUT);
  pinMode(led2, OUTPUT);
  pinMode(led3, OUTPUT);
  pinMode(led4, OUTPUT);
}

void loop() {
  // --- Ejemplo de secuencia: Encendido progresivo ---
  
  digitalWrite(led1, HIGH); // Enciende el primer LED
  delay(500);               // Espera medio segundo
  
  digitalWrite(led2, HIGH); // Enciende el segundo LED
  delay(500);
  
  digitalWrite(led3, HIGH); // Enciende el tercer LED (Como se ve en la foto)
  delay(500);
  
  digitalWrite(led4, HIGH); // Enciende el cuarto LED
  delay(500);

  // --- Apagado progresivo ---
  
  digitalWrite(led1, LOW);  // Apaga el primer LED
  delay(500);
  
  digitalWrite(led2, LOW);  // Apaga el segundo LED
  delay(500);
  
  digitalWrite(led3, LOW);  // Apaga el tercer LED
  delay(500);
  
  digitalWrite(led4, LOW);  // Apaga el cuarto LED
  delay(500);
}
